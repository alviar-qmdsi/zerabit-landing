---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const openRoles = [
  {
    title: 'Senior Full-Stack Engineer',
    type: 'Full-time · Contract',
    location: 'Remote (Global)',
    description: 'We\'re looking for a senior engineer who thrives in a client-facing consulting environment. You\'ll be the technical lead on 1-2 projects at a time, architecting solutions and mentoring junior engineers.',
    requirements: ['5+ years of full-stack experience', 'Strong TypeScript / Node.js', 'React or Next.js proficiency', 'Experience with cloud platforms (AWS/GCP/Azure)', 'Excellent written communication'],
    gradient: 'from-indigo-500 to-violet-600',
    shadow: 'shadow-indigo-500/20',
  },
  {
    title: 'UI/UX Designer',
    type: 'Full-time · Contract',
    location: 'Remote (Global)',
    description: 'A design generalist with strong visual instincts and the ability to translate ambiguous briefs into polished, user-tested designs. You\'ll own the design process end-to-end for multiple client projects.',
    requirements: ['4+ years of product/UI design', 'Expert-level Figma skills', 'Experience designing SaaS or B2B products', 'Comfort with HTML/CSS is a plus', 'Portfolio demonstrating UX rationale'],
    gradient: 'from-pink-500 to-rose-600',
    shadow: 'shadow-pink-500/20',
  },
  {
    title: 'DevOps / Platform Engineer',
    type: 'Part-time · Contract',
    location: 'Remote (Global)',
    description: 'Help our clients build and maintain rock-solid cloud infrastructure. You\'ll be brought in for infrastructure audits, migrations, and ongoing support — working closely with our engineering team.',
    requirements: ['3+ years of DevOps/SRE experience', 'Terraform and Kubernetes', 'AWS certifications preferred', 'CI/CD pipeline expertise', 'Strong security mindset'],
    gradient: 'from-sky-500 to-blue-600',
    shadow: 'shadow-sky-500/20',
  },
];

const benefits = [
  {
    title: 'Fully remote',
    description: 'Work from anywhere in the world. We\'re async-first and results-focused.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>`,
    gradient: 'from-indigo-500 to-violet-600',
  },
  {
    title: 'Competitive pay',
    description: 'Top-of-market rates benchmarked against global engineering compensation data.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
    </svg>`,
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    title: 'Interesting problems',
    description: 'Work on varied, challenging projects across industries — no two sprints look the same.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 10.5 6.75l4.5 4.5 3.75-3.75" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6.75h3.75v3.75" />
    </svg>`,
    gradient: 'from-amber-500 to-orange-500',
  },
  {
    title: 'Annual retreat',
    description: 'We bring the team together once a year for a week of collaboration, workshops, and fun.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
    </svg>`,
    gradient: 'from-violet-500 to-purple-600',
  },
  {
    title: 'Learning budget',
    description: '$1,500/year for courses, books, conferences, or whatever helps you grow.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
    </svg>`,
    gradient: 'from-sky-500 to-blue-600',
  },
  {
    title: 'Async-first culture',
    description: 'We minimise meetings and respect deep work time. Most communication is written and asynchronous.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
    </svg>`,
    gradient: 'from-pink-500 to-rose-600',
  },
];
---

<Layout title="Careers — Zerabit Solutions" description="Join the Zerabit team. Work on interesting problems, with great people, fully remote. View open roles.">
  <Nav activePage="/careers" />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gray-950 pt-24 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="hero-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div aria-hidden="true" class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-indigo-600 opacity-10 blur-3xl pointer-events-none animate-pulse-slow"></div>
      <div aria-hidden="true" class="absolute -bottom-40 -left-20 w-[500px] h-[500px] rounded-full bg-violet-600 opacity-8 blur-3xl pointer-events-none animate-pulse-slow-delay"></div>
      <div class="relative max-w-6xl mx-auto">
        <div class="max-w-3xl reveal-up">
          <span class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-semibold uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            {openRoles.length} roles open
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
            Build great software.<br />
            <span class="hero-gradient-text">Work with great people.</span>
          </h1>
          <p class="text-lg text-gray-400 max-w-2xl leading-relaxed">
            Zerabit is a remote-first team of engineers and designers who care deeply about craft. If you want interesting problems and real ownership, you'll fit right in.
          </p>
        </div>
      </div>
    </section>

    <!-- Culture section -->
    <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-900">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal-up">
          <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Our culture</span>
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-5 tracking-tight">How we work</h2>
          <div class="space-y-4 text-gray-400 leading-relaxed">
            <p>
              We're a lean team that punches above its weight. There's no bureaucracy, no endless meetings, and no one to hide behind. You'll have real ownership over your work and see its direct impact on clients.
            </p>
            <p>
              We communicate in writing, respect deep work time, and hold each other to high standards without the toxicity. If you're the kind of person who opens a PR and immediately wants to make it better — you'll thrive here.
            </p>
          </div>
        </div>
        <!-- Culture grid placeholder -->
        <div class="grid grid-cols-2 gap-3 reveal-up" style="animation-delay: 150ms;">
          {['Deep work culture', 'High ownership', 'Senior peers', 'No micro-management'].map((label, i) => (
            <div
              class={`relative rounded-xl overflow-hidden bg-gradient-to-br ${i === 0 ? 'from-indigo-950 to-gray-900' : i === 1 ? 'from-violet-950 to-gray-900' : i === 2 ? 'from-sky-950 to-gray-900' : 'from-emerald-950 to-gray-900'} border border-white/5 aspect-square flex items-end p-4`}
            >
              <div aria-hidden="true" class="absolute inset-0 hero-grid opacity-20"></div>
              <span class="relative text-xs font-semibold text-gray-300">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-950">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-up">
          <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Perks & benefits</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 tracking-tight">What we offer</h2>
          <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
            We invest in the people who make Zerabit great.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {benefits.map((b, i) => (
            <div
              class="group p-6 rounded-2xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/80 hover:bg-gray-900 transition-all duration-300 reveal-up"
              style={`animation-delay: ${i * 70}ms`}
            >
              <div class={`inline-flex w-10 h-10 rounded-xl bg-gradient-to-br ${b.gradient} items-center justify-center mb-4 text-white shadow-md group-hover:scale-110 transition-transform duration-300`}>
                <div class="w-5 h-5" set:html={b.icon} />
              </div>
              <h3 class="text-sm font-semibold text-white mb-2">{b.title}</h3>
              <p class="text-sm text-gray-400 leading-relaxed">{b.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open roles -->
    <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-900">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-up">
          <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Open positions</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 tracking-tight">Current openings</h2>
          <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
            We hire slowly and deliberately. If you think you're a fit, apply — even if none of the roles below are perfect.
          </p>
        </div>

        <div class="space-y-5">
          {openRoles.map((role, i) => (
            <div
              class={`group rounded-2xl bg-gray-950/60 border border-gray-800/60 hover:border-gray-700/80 hover:bg-gray-950 transition-all duration-300 p-6 reveal-up`}
              style={`animation-delay: ${i * 80}ms`}
            >
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
                <div>
                  <div class="flex items-center gap-3 mb-1.5">
                    <div class={`w-2 h-2 rounded-full bg-gradient-to-br ${role.gradient}`}></div>
                    <h3 class="text-lg font-bold text-white">{role.title}</h3>
                  </div>
                  <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 pl-5">
                    <span>{role.type}</span>
                    <span>·</span>
                    <span>{role.location}</span>
                  </div>
                </div>
                <a
                  href={`/contact?role=${encodeURIComponent(role.title)}`}
                  class={`flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-gradient-to-r ${role.gradient} text-white text-sm font-semibold hover:opacity-90 transition-opacity duration-200 shadow-md ${role.shadow} whitespace-nowrap`}
                >
                  Apply now
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
              <p class="text-sm text-gray-400 leading-relaxed mb-4 pl-5">{role.description}</p>
              <div class="pl-5">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Requirements</p>
                <ul class="flex flex-wrap gap-2">
                  {role.requirements.map((req) => (
                    <li class="px-3 py-1 rounded-full bg-gray-800/60 border border-gray-700/60 text-xs text-gray-300">{req}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        <!-- General application -->
        <div class="mt-8 rounded-2xl bg-gradient-to-br from-indigo-950 to-gray-900 border border-indigo-500/20 p-6 text-center reveal-up">
          <h3 class="text-base font-semibold text-white mb-2">Don't see a perfect fit?</h3>
          <p class="text-sm text-gray-400 mb-4">We're always open to hearing from exceptional people. Send us a note — the right person creates the role.</p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white/10 border border-white/10 text-white text-sm font-semibold hover:bg-white/15 hover:border-white/20 transition-all duration-200"
          >
            Send a general application
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );
    document.querySelectorAll('.reveal-up').forEach((el) => observer.observe(el));
  </script>
</Layout>
