---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import TechStack from '../components/TechStack.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';

const features = [
  {
    title: 'Rapid Delivery',
    description:
      'Ship production-ready software in weeks, not months. Our agile teams move fast without cutting corners.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
    </svg>`,
    gradient: 'from-amber-500 to-orange-500',
    shadow: 'shadow-amber-500/20',
  },
  {
    title: 'Cloud-Native Infrastructure',
    description:
      'Scalable, resilient deployments on AWS, GCP, or Azure — fully managed so you can focus on your product.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
    </svg>`,
    gradient: 'from-sky-500 to-blue-600',
    shadow: 'shadow-sky-500/20',
  },
  {
    title: 'Security by Default',
    description:
      'SOC 2 aligned practices, end-to-end encryption, and proactive vulnerability monitoring built into every engagement.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
    </svg>`,
    gradient: 'from-emerald-500 to-teal-600',
    shadow: 'shadow-emerald-500/20',
  },
  {
    title: 'Dedicated Partnership',
    description:
      'A dedicated team that acts as an extension of yours — transparent communication, shared goals, real accountability.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
    </svg>`,
    gradient: 'from-violet-500 to-purple-600',
    shadow: 'shadow-violet-500/20',
  },
];

const stats = [
  { value: 50, suffix: '+', label: 'Projects shipped' },
  { value: 98, suffix: '%', label: 'Client retention' },
  { value: 3, suffix: '×', label: 'Faster time-to-market' },
  { value: 24, suffix: '/7', label: 'Dedicated support' },
];

const barHeights = [40, 55, 35, 70, 50, 85, 60, 90, 72, 88];
---

<Layout>
  <Nav activePage="/" />

  <main>
    <!-- ═══════════════════════════════════════
         HERO — split layout with dashboard mockup
    ════════════════════════════════════════ -->
    <section class="relative overflow-hidden bg-gray-950 min-h-[92vh] flex items-center pt-16 pb-28 px-4 sm:px-6 lg:px-8">

      <!-- Background grid -->
      <div class="hero-grid absolute inset-0 opacity-[0.15]" aria-hidden="true"></div>

      <!-- Noise texture -->
      <div class="noise-overlay absolute inset-0" aria-hidden="true"></div>

      <!-- Aurora orbs -->
      <div aria-hidden="true" class="aurora-1 absolute -top-60 -right-40 w-[800px] h-[800px] rounded-full bg-indigo-600 blur-3xl pointer-events-none"></div>
      <div aria-hidden="true" class="aurora-2 absolute -bottom-60 -left-20 w-[600px] h-[600px] rounded-full bg-violet-700 blur-3xl pointer-events-none"></div>
      <div aria-hidden="true" class="aurora-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full bg-indigo-500 blur-3xl pointer-events-none opacity-5"></div>

      <div class="relative max-w-7xl mx-auto w-full">
        <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-center">

          <!-- ── Left: copy ── -->
          <div class="reveal-up">
            <div class="inline-flex items-center gap-2 mb-8 px-3.5 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-semibold uppercase tracking-wider">
              <span class="relative flex w-2 h-2">
                <span class="badge-ping absolute inline-flex w-full h-full rounded-full bg-indigo-400 opacity-75"></span>
                <span class="relative inline-flex w-2 h-2 rounded-full bg-indigo-400"></span>
              </span>
              Trusted by growing teams
            </div>

            <h1 class="text-5xl sm:text-6xl xl:text-[4.5rem] font-black text-white leading-[1.02] tracking-tight mb-8">
              Software built<br />
              <span class="hero-gradient-text">for the long run</span>
            </h1>

            <p class="text-lg sm:text-xl text-gray-400 mb-10 max-w-lg leading-relaxed">
              Zerabit Solutions partners with ambitious teams to design, build, and scale digital
              products — from MVP to enterprise. No lock-in, no bloat, just great software.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="#contact"
                class="btn-shimmer inline-flex justify-center items-center gap-2 px-7 py-4 rounded-xl text-white text-base font-bold shadow-xl shadow-indigo-500/30 hover:-translate-y-0.5"
              >
                Start a project
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a
                href="#services"
                class="inline-flex justify-center items-center gap-2 px-7 py-4 rounded-xl bg-white/5 border border-white/10 text-white text-base font-semibold hover:bg-white/10 hover:border-white/25 transition-all duration-200"
              >
                See what we do
              </a>
            </div>
          </div>

          <!-- ── Right: floating dashboard mockup ── -->
          <div class="hidden lg:block reveal-right relative">
            <div class="relative w-full max-w-md xl:max-w-lg mx-auto">

              <!-- Main card: metrics dashboard -->
              <div class="animate-float-a relative rounded-2xl overflow-hidden border border-white/10 bg-gray-900/80 backdrop-blur-md shadow-2xl shadow-indigo-900/30">
                <!-- Card chrome bar -->
                <div class="flex items-center gap-2 px-5 py-3 border-b border-white/[0.06] bg-gray-950/50">
                  <div class="flex gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-amber-500/70"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/70"></div>
                  </div>
                  <span class="text-[11px] text-gray-500 font-mono ml-2">zerabit — project-dashboard</span>
                </div>

                <!-- Card body -->
                <div class="p-5">
                  <!-- Chart header -->
                  <div class="flex items-center justify-between mb-3">
                    <div>
                      <p class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Sprint velocity</p>
                      <p class="text-xl font-black text-white mt-0.5">24 pts<span class="text-sm font-normal text-gray-500"> / week</span></p>
                    </div>
                    <span class="inline-flex items-center gap-1 text-xs font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
                      </svg>
                      +24%
                    </span>
                  </div>

                  <!-- Bar chart -->
                  <div class="flex items-end gap-1 h-16 mb-4">
                    {barHeights.map((h, i) => (
                      <div
                        class="flex-1 rounded-sm"
                        style={`height: ${h}%; background: linear-gradient(to top, rgba(99,102,241,${0.4 + i * 0.04}), rgba(139,92,246,0.7)); opacity: ${i === barHeights.length - 1 ? 1 : 0.5 + i * 0.05}`}
                      ></div>
                    ))}
                  </div>

                  <!-- Metrics row -->
                  <div class="grid grid-cols-3 gap-3 pt-4 border-t border-white/[0.06]">
                    <div>
                      <p class="text-base font-black text-white">99.9%</p>
                      <p class="text-[11px] text-gray-500 mt-0.5">Uptime</p>
                    </div>
                    <div>
                      <p class="text-base font-black text-white">1.8ms</p>
                      <p class="text-[11px] text-gray-500 mt-0.5">Avg latency</p>
                    </div>
                    <div>
                      <p class="text-base font-black text-white">14</p>
                      <p class="text-[11px] text-gray-500 mt-0.5">Deploys today</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Floating status badge (top-right) -->
              <div class="animate-float-b absolute -top-5 -right-6 rounded-xl border border-white/10 bg-gray-900/90 backdrop-blur-sm shadow-xl px-4 py-3 min-w-[11rem]">
                <div class="flex items-center gap-2 mb-1">
                  <span class="relative flex w-2 h-2">
                    <span class="badge-ping absolute inline-flex w-full h-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex w-2 h-2 rounded-full bg-emerald-400"></span>
                  </span>
                  <span class="text-xs font-bold text-white">All systems live</span>
                </div>
                <p class="text-[11px] text-gray-500 pl-4">6 services · 0 incidents</p>
              </div>

              <!-- Floating deploy success card (bottom-left) -->
              <div class="animate-float-c absolute -bottom-5 -left-6 rounded-xl border border-emerald-500/20 bg-gray-900/90 backdrop-blur-sm shadow-xl px-4 py-3 min-w-[13rem]">
                <div class="flex items-center gap-2">
                  <div class="flex-shrink-0 w-7 h-7 rounded-lg bg-emerald-500/15 border border-emerald-500/20 flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-bold text-emerald-400">Deployed successfully</p>
                    <p class="text-[11px] text-gray-500">v2.4.1 → production</p>
                  </div>
                </div>
              </div>

              <!-- Subtle reflection/glow below card -->
              <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-3/4 h-16 bg-indigo-600 opacity-10 blur-2xl rounded-full pointer-events-none" aria-hidden="true"></div>
            </div>
          </div>

        </div>

        <!-- Stats row -->
        <div class="mt-20 grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/[0.05] rounded-2xl overflow-hidden reveal-up-delay">
          {stats.map((s) => (
            <div class="bg-gray-950/70 px-6 py-6 text-center hover:bg-white/[0.04] transition-colors duration-300 group">
              <div class="text-3xl font-black text-white mb-1 counter-value group-hover:scale-105 transition-transform duration-200">
                <span class="counter-num" data-target={s.value}>{s.value}</span>{s.suffix}
              </div>
              <div class="text-sm text-gray-500">{s.label}</div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <div class="gradient-divider"></div>

    <!-- Services -->
    <Services />

    <div class="gradient-divider"></div>

    <!-- Features / Why Zerabit -->
    <section id="features" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-900">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal-up">
          <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Why Zerabit</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
            Why teams choose us
          </h2>
          <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
            We combine deep technical expertise with a product-first mindset to deliver outcomes
            that matter.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {
            features.map((f, i) => (
              <div
                class={`feature-card glow-card group relative p-6 rounded-2xl bg-gray-800/50 border border-gray-700/50 hover:border-gray-600/80 hover:bg-gray-800 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-2xl ${f.shadow} reveal-up`}
                style={`animation-delay: ${i * 100}ms`}
              >
                <div class={`inline-flex w-12 h-12 rounded-xl bg-gradient-to-br ${f.gradient} items-center justify-center mb-5 text-white shadow-lg ${f.shadow} group-hover:scale-110 transition-transform duration-300`}>
                  <div class="w-6 h-6" set:html={f.icon} />
                </div>
                <h3 class="text-base font-semibold text-white mb-2.5">{f.title}</h3>
                <p class="text-sm text-gray-400 leading-relaxed">{f.description}</p>
                <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${f.gradient} opacity-0 group-hover:opacity-5 transition-opacity duration-300 pointer-events-none`}></div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="gradient-divider"></div>

    <!-- Process -->
    <Process />

    <div class="gradient-divider"></div>

    <!-- Tech Stack -->
    <TechStack />

    <div class="gradient-divider"></div>

    <!-- Testimonials -->
    <Testimonials />

    <div class="gradient-divider"></div>

    <!-- Mid-page CTA -->
    <section id="about" class="relative overflow-hidden py-28 px-4 sm:px-6 lg:px-8 bg-gray-950">
      <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-br from-indigo-950 via-gray-950 to-violet-950 opacity-80"></div>
      <div aria-hidden="true" class="absolute inset-0">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-px bg-gradient-to-r from-transparent via-indigo-500/40 to-transparent"></div>
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-px bg-gradient-to-r from-transparent via-violet-500/40 to-transparent"></div>
      </div>
      <div
        aria-hidden="true"
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full bg-indigo-600 opacity-10 blur-3xl pointer-events-none"
      ></div>
      <div class="noise-overlay absolute inset-0" aria-hidden="true"></div>

      <div class="relative max-w-4xl mx-auto text-center reveal-up">
        <span class="inline-block mb-5 px-4 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-semibold uppercase tracking-wider">
          Ready to ship?
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 tracking-tight">
          Ready to move faster?
        </h2>
        <p class="text-gray-400 text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
          Whether you need a full product team or an expert to accelerate your roadmap, we're ready
          to help. Let's talk about what you're building.
        </p>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white text-gray-900 text-base font-black hover:bg-gray-100 transition-all duration-200 shadow-2xl hover:-translate-y-0.5"
        >
          Book a free discovery call
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </section>

    <div class="gradient-divider"></div>

    <!-- FAQ -->
    <FAQ />

    <div class="gradient-divider"></div>

    <!-- Contact -->
    <section id="contact" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-900">
      <div class="max-w-2xl mx-auto text-center reveal-up">
        <span class="inline-block mb-4 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Get in touch</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight">
          Let's build something great
        </h2>
        <p class="text-gray-400 text-lg mb-10 leading-relaxed">
          Drop us a line and we'll get back to you within one business day.
        </p>
        <form
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
          onsubmit="return false;"
          aria-label="Contact form"
        >
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-4 py-3.5 rounded-xl bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600"
            required
            aria-label="Email address"
          />
          <button
            type="submit"
            class="btn-shimmer px-6 py-3.5 rounded-xl text-white font-bold text-sm whitespace-nowrap shadow-lg shadow-indigo-500/25"
          >
            Get in touch
          </button>
        </form>
        <p class="mt-4 text-xs text-gray-600">No spam, ever. Unsubscribe at any time.</p>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Scroll reveal + count-up -->
  <script>
    // Intersection Observer for scroll-triggered reveals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );

    document.querySelectorAll('.reveal-up, .reveal-up-delay, .reveal-right').forEach((el) => {
      observer.observe(el);
    });

    // Animated counter
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    document.querySelectorAll<HTMLElement>('.counter-num').forEach((el) => {
      const target = parseInt(el.dataset.target ?? '0', 10);
      const duration = 1600;
      let startTime: number | null = null;

      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            counterObserver.unobserve(entry.target);

            const animate = (timestamp: number) => {
              if (!startTime) startTime = timestamp;
              const progress = Math.min((timestamp - startTime) / duration, 1);
              el.textContent = String(Math.round(easeOut(progress) * target));
              if (progress < 1) requestAnimationFrame(animate);
            };
            requestAnimationFrame(animate);
          });
        },
        { threshold: 0.5 }
      );

      counterObserver.observe(el);
    });
  </script>
</Layout>
