---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: '⚡',
    title: 'Rapid Delivery',
    description:
      'Ship production-ready software in weeks, not months. Our agile teams move fast without cutting corners.',
  },
  {
    icon: '☁️',
    title: 'Cloud-Native Infrastructure',
    description:
      'Scalable, resilient deployments on AWS, GCP, or Azure — fully managed so you can focus on your product.',
  },
  {
    icon: '🔒',
    title: 'Security by Default',
    description:
      'SOC 2 aligned practices, end-to-end encryption, and proactive vulnerability monitoring built into every engagement.',
  },
  {
    icon: '🤝',
    title: 'Dedicated Partnership',
    description:
      'A dedicated team that acts as an extension of yours — transparent communication, shared goals, real accountability.',
  },
];
---

<Layout>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <a href="/" class="text-xl font-bold tracking-tight text-gray-900">
        Zerabit<span class="text-indigo-600">.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#features" class="hover:text-gray-900 transition-colors">Services</a>
        <a href="#about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="#contact" class="hover:text-gray-900 transition-colors">Contact</a>
      </div>
      <a
        href="#contact"
        class="inline-flex items-center px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition-colors"
      >
        Get in touch
      </a>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-white pt-20 pb-24 px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="max-w-3xl">
          <span class="inline-block mb-4 px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold uppercase tracking-wide">
            Trusted by growing teams
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
            Software built for<br />
            <span class="text-indigo-600">the long run</span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-500 mb-8 max-w-2xl">
            Zerabit Solutions partners with ambitious teams to design, build, and scale digital
            products — from MVP to enterprise. No lock-in, no bloat, just great software.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contact"
              class="inline-flex justify-center items-center px-6 py-3 rounded-xl bg-indigo-600 text-white text-base font-semibold hover:bg-indigo-700 transition-colors shadow-md"
            >
              Start a project
            </a>
            <a
              href="#features"
              class="inline-flex justify-center items-center px-6 py-3 rounded-xl bg-white border border-gray-200 text-gray-700 text-base font-semibold hover:bg-gray-50 transition-colors"
            >
              See what we do
            </a>
          </div>
        </div>
      </div>
      <!-- Decorative blob -->
      <div
        aria-hidden="true"
        class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-indigo-100 opacity-30 blur-3xl pointer-events-none"
      ></div>
    </section>

    <!-- Features / Value Props -->
    <section id="features" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
            Why teams choose Zerabit
          </h2>
          <p class="text-gray-500 max-w-xl mx-auto text-lg">
            We combine deep technical expertise with a product-first mindset to deliver outcomes
            that matter.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            features.map((f) => (
              <div class="group p-6 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:border-indigo-200 hover:shadow-lg transition-all duration-200">
                <div class="text-3xl mb-4">{f.icon}</div>
                <h3 class="text-base font-semibold text-gray-900 mb-2">{f.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{f.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Mid-page CTA -->
    <section id="about" class="py-20 px-4 sm:px-6 lg:px-8 bg-indigo-600">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          Ready to move faster?
        </h2>
        <p class="text-indigo-200 text-lg mb-8 max-w-2xl mx-auto">
          Whether you need a full product team or an expert to accelerate your roadmap, we're ready
          to help. Let's talk about what you're building.
        </p>
        <a
          href="#contact"
          class="inline-flex items-center px-8 py-4 rounded-xl bg-white text-indigo-600 text-base font-bold hover:bg-indigo-50 transition-colors shadow-md"
        >
          Book a free discovery call
        </a>
      </div>
    </section>

    <!-- Contact / Bottom CTA -->
    <section id="contact" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Let's build something great
        </h2>
        <p class="text-gray-500 text-lg mb-8">
          Drop us a line and we'll get back to you within one business day.
        </p>
        <form
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
          onsubmit="return false;"
        >
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-4 py-3 rounded-xl border border-gray-200 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm"
            required
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-xl bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-700 transition-colors whitespace-nowrap"
          >
            Get in touch
          </button>
        </form>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-100 bg-gray-50 py-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-gray-500">
      <p class="font-semibold text-gray-900 text-base">
        Zerabit<span class="text-indigo-600">.</span>
      </p>
      <nav class="flex flex-wrap justify-center gap-6">
        <a href="#features" class="hover:text-gray-900 transition-colors">Services</a>
        <a href="#about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="#contact" class="hover:text-gray-900 transition-colors">Contact</a>
      </nav>
      <div class="flex items-center gap-4">
        <!-- GitHub -->
        <a
          href="https://github.com"
          aria-label="GitHub"
          class="hover:text-gray-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.745 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
        <!-- LinkedIn -->
        <a
          href="https://linkedin.com"
          aria-label="LinkedIn"
          class="hover:text-gray-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            />
          </svg>
        </a>
        <!-- Twitter/X -->
        <a
          href="https://twitter.com"
          aria-label="Twitter"
          class="hover:text-gray-900 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            />
          </svg>
        </a>
      </div>
      <p>&copy; {new Date().getFullYear()} Zerabit Solutions. All rights reserved.</p>
    </div>
  </footer>
</Layout>
