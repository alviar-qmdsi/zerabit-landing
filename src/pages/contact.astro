---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const contactDetails = [
  {
    label: 'Email',
    value: 'hello@zerabit.io',
    href: 'mailto:hello@zerabit.io',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
    </svg>`,
  },
  {
    label: 'Phone',
    value: '+1 (555) 000-1234',
    href: 'tel:+15550001234',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
    </svg>`,
  },
  {
    label: 'Response time',
    value: 'Within 1 business day',
    href: null,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>`,
  },
];

const budgetRanges = [
  'Under $10k',
  '$10k – $25k',
  '$25k – $50k',
  '$50k – $100k',
  '$100k+',
  'Not sure yet',
];

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.745 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>`,
  },
  {
    label: 'Twitter',
    href: 'https://twitter.com',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>`,
  },
];
---

<Layout title="Contact — Zerabit Solutions" description="Get in touch with Zerabit Solutions. Start a project, book a discovery call, or just say hello.">
  <Nav activePage="/contact" />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gray-950 pt-24 pb-16 px-4 sm:px-6 lg:px-8">
      <div class="hero-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div aria-hidden="true" class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-indigo-600 opacity-10 blur-3xl pointer-events-none animate-pulse-slow"></div>
      <div class="relative max-w-6xl mx-auto">
        <div class="max-w-2xl reveal-up">
          <span class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-semibold uppercase tracking-wider">
            Get in touch
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
            Let's build<br />
            <span class="hero-gradient-text">something great</span>
          </h1>
          <p class="text-lg text-gray-400 leading-relaxed">
            Tell us about your project. We'll get back to you within one business day with thoughts and next steps.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact grid -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-950">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Sidebar -->
        <aside class="space-y-8">
          <!-- Contact details -->
          <div class="rounded-2xl bg-gray-900/60 border border-gray-800/60 p-6 reveal-up">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-5">Direct contact</h2>
            <ul class="space-y-5">
              {contactDetails.map((detail) => (
                <li class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400">
                    <div class="w-4 h-4" set:html={detail.icon} />
                  </div>
                  <div>
                    <p class="text-xs text-gray-500 mb-0.5">{detail.label}</p>
                    {detail.href ? (
                      <a href={detail.href} class="text-sm text-white hover:text-indigo-400 transition-colors duration-200 font-medium">{detail.value}</a>
                    ) : (
                      <p class="text-sm text-white font-medium">{detail.value}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Office location placeholder -->
          <div class="rounded-2xl bg-gray-900/60 border border-gray-800/60 overflow-hidden reveal-up" style="animation-delay: 80ms;">
            <div class="relative bg-gradient-to-br from-indigo-950 to-gray-900 aspect-[16/10] flex items-center justify-center">
              <div aria-hidden="true" class="absolute inset-0 hero-grid opacity-30"></div>
              <div class="relative text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-indigo-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <p class="text-sm text-gray-400">Remote-first · Global</p>
              </div>
            </div>
            <div class="p-4">
              <p class="text-sm text-gray-400">We work with clients worldwide. Meetings are held via Zoom or Google Meet in your timezone.</p>
            </div>
          </div>

          <!-- Social links -->
          <div class="rounded-2xl bg-gray-900/60 border border-gray-800/60 p-6 reveal-up" style="animation-delay: 160ms;">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Follow us</h2>
            <div class="flex items-center gap-4">
              {socialLinks.map((s) => (
                <a
                  href={s.href}
                  aria-label={s.label}
                  class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-500 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all duration-200"
                >
                  <Fragment set:html={s.icon} />
                </a>
              ))}
            </div>
          </div>
        </aside>

        <!-- Form -->
        <div class="lg:col-span-2 reveal-up" style="animation-delay: 60ms;">
          <div class="rounded-2xl bg-gray-900/60 border border-gray-800/60 p-8">
            <h2 class="text-xl font-bold text-white mb-6">Tell us about your project</h2>
            <form class="space-y-5" onsubmit="return false;" aria-label="Contact form">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-300 mb-1.5">Full name <span class="text-indigo-400">*</span></label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Jane Smith"
                    class="w-full px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">Work email <span class="text-indigo-400">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="jane@company.com"
                    class="w-full px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600"
                  />
                </div>
              </div>

              <div>
                <label for="company" class="block text-sm font-medium text-gray-300 mb-1.5">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="Acme Inc."
                  class="w-full px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600"
                />
              </div>

              <div>
                <label for="budget" class="block text-sm font-medium text-gray-300 mb-1.5">Budget range</label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 text-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600 appearance-none"
                >
                  <option value="" disabled selected>Select a range…</option>
                  {budgetRanges.map((r) => (
                    <option value={r}>{r}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-300 mb-1.5">Message <span class="text-indigo-400">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows={5}
                  placeholder="Tell us about your project — what you're building, your timeline, and any specific challenges you're facing."
                  class="w-full px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition-colors duration-200 hover:border-gray-600 resize-vertical"
                ></textarea>
              </div>

              <div class="flex items-center justify-between pt-2">
                <p class="text-xs text-gray-600">No spam, ever. We'll only contact you about your inquiry.</p>
                <button
                  type="submit"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-500 transition-all duration-200 shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5 whitespace-nowrap"
                >
                  Send message
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );
    document.querySelectorAll('.reveal-up').forEach((el) => observer.observe(el));
  </script>
</Layout>
