---
const faqs = [
  {
    question: 'What types of projects do you take on?',
    answer:
      'We work across the full spectrum — from greenfield web and mobile apps to legacy modernization, cloud migrations, and AI integrations. If it involves code and ambition, we\'re interested.',
  },
  {
    question: 'How long does a typical project take?',
    answer:
      'Timelines vary by scope, but most MVPs ship within 6–10 weeks. We\'ll give you a realistic estimate after a discovery call, and we stick to it.',
  },
  {
    question: 'Do you work with early-stage startups?',
    answer:
      'Absolutely. Some of our best work has been helping founders go from idea to launch. We\'re comfortable working with ambiguity and can help you prioritize ruthlessly.',
  },
  {
    question: 'What does your engagement model look like?',
    answer:
      'We offer fixed-scope projects and retainer-based partnerships. Both come with a dedicated team, weekly syncs, and full visibility into progress via shared tooling.',
  },
  {
    question: 'Who owns the code when the project is done?',
    answer:
      'You do — always. We hand over full source code, documentation, and deployment runbooks. No lock-in, no hidden dependencies on us.',
  },
  {
    question: 'How do I get started?',
    answer:
      'Drop your email in the form below and we\'ll schedule a free 30-minute discovery call. No pitch decks, no pressure — just a real conversation about what you\'re building.',
  },
];
---

<section id="faq" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-950">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Questions</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Frequently asked
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed">
        Everything you need to know before starting a project with us.
      </p>
    </div>

    <div class="space-y-3 reveal-up">
      {faqs.map((faq, i) => (
        <div class="faq-item rounded-xl border border-gray-800/60 bg-gray-900/60 overflow-hidden" data-index={i}>
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left text-white font-semibold text-sm hover:bg-gray-800/40 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500"
            aria-expanded="false"
            type="button"
          >
            <span>{faq.question}</span>
            <span class="faq-icon flex-shrink-0 flex items-center justify-center w-6 h-6 rounded-full border border-gray-700 text-gray-400 transition-transform duration-300" aria-hidden="true">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </span>
          </button>
          <div class="faq-body hidden px-6 pb-5">
            <p class="text-sm text-gray-400 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger');
    const body = item.querySelector<HTMLElement>('.faq-body');
    const icon = item.querySelector<HTMLElement>('.faq-icon');

    if (!trigger || !body || !icon) return;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close any other open items
      document.querySelectorAll<HTMLElement>('.faq-item').forEach((other) => {
        if (other !== item) {
          const otherTrigger = other.querySelector<HTMLButtonElement>('.faq-trigger');
          const otherBody = other.querySelector<HTMLElement>('.faq-body');
          const otherIcon = other.querySelector<HTMLElement>('.faq-icon');
          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
          if (otherBody) otherBody.classList.add('hidden');
          if (otherIcon) {
            otherIcon.style.transform = 'rotate(0deg)';
            otherIcon.style.borderColor = '';
            otherIcon.style.color = '';
          }
        }
      });

      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        body.classList.add('hidden');
        icon.style.transform = 'rotate(0deg)';
        icon.style.borderColor = '';
        icon.style.color = '';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        body.classList.remove('hidden');
        icon.style.transform = 'rotate(45deg)';
        icon.style.borderColor = 'rgb(99 102 241 / 0.5)';
        icon.style.color = 'rgb(129 140 248)';
      }
    });
  });
</script>
