---
const testimonials = [
  {
    quote:
      "Zerabit took our rough idea and turned it into a polished product in under two months. The communication was exceptional — we always knew exactly where things stood.",
    name: 'Sarah Chen',
    role: 'Co-founder & CTO',
    company: 'Luminary Health',
    gradient: 'from-indigo-500 to-violet-500',
  },
  {
    quote:
      "We hired Zerabit to rebuild our data pipeline from scratch. They delivered a system that processes 10× the volume with half the infrastructure cost. Genuinely impressive.",
    name: 'Marcus Rivera',
    role: 'VP of Engineering',
    company: 'FlowMetrics',
    gradient: 'from-emerald-500 to-teal-500',
  },
  {
    quote:
      "The design system they built has become the foundation our entire product team works from. It's maintainable, beautiful, and our devs actually enjoy using it.",
    name: 'Priya Nair',
    role: 'Head of Product',
    company: 'Stackform',
    gradient: 'from-amber-500 to-orange-500',
  },
];
---

<section id="testimonials" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-900">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Client stories</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Trusted by builders
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
        Don't take our word for it — hear from the teams we've shipped with.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="relative flex flex-col p-7 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/8 hover:border-white/20 transition-all duration-300 hover:-translate-y-1 reveal-up"
          style={`animation-delay: ${i * 100}ms`}
        >
          <!-- Quote mark -->
          <div class={`absolute top-6 right-7 text-5xl font-serif font-bold leading-none bg-gradient-to-br ${t.gradient} bg-clip-text text-transparent opacity-40 select-none`} aria-hidden="true">"</div>

          <!-- Stars -->
          <div class="flex gap-0.5 mb-5" aria-label="5 out of 5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" />
              </svg>
            ))}
          </div>

          <blockquote class="flex-1 text-gray-300 text-sm leading-relaxed mb-6">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-5 border-t border-white/10">
            <div class={`flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br ${t.gradient} flex items-center justify-center text-white text-sm font-bold shadow-md`}>
              {t.name.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-gray-500">{t.role} · {t.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
