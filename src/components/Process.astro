---
const steps = [
  {
    number: '01',
    title: 'Discovery',
    description: 'We dig into your goals, users, and constraints to align on scope and success metrics before writing a single line of code.',
    gradient: 'from-indigo-500 to-violet-500',
  },
  {
    number: '02',
    title: 'Strategy',
    description: 'Architecture decisions, tech stack selection, and a clear roadmap — so every sprint moves the needle.',
    gradient: 'from-violet-500 to-purple-500',
  },
  {
    number: '03',
    title: 'Design',
    description: 'High-fidelity prototypes and a design system that keeps the product coherent as it scales.',
    gradient: 'from-purple-500 to-pink-500',
  },
  {
    number: '04',
    title: 'Development',
    description: 'Iterative builds with continuous delivery, code reviews, and transparent progress updates every step of the way.',
    gradient: 'from-pink-500 to-rose-500',
  },
  {
    number: '05',
    title: 'Launch',
    description: 'Deployment to production with monitoring, performance baselines, and a handoff package your team can own confidently.',
    gradient: 'from-rose-500 to-orange-500',
  },
];
---

<section id="process" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-900">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">How we work</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Our process
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
        A proven, repeatable framework that turns ambiguous ideas into polished, production-ready software.
      </p>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden lg:block reveal-up">
      <div class="relative flex items-start gap-0">
        <!-- Connecting line -->
        <div class="absolute top-8 left-[calc(10%+1.5rem)] right-[calc(10%+1.5rem)] h-px bg-gradient-to-r from-indigo-500/30 via-purple-500/30 to-orange-500/30" aria-hidden="true"></div>

        {steps.map((step, i) => (
          <div class="flex-1 flex flex-col items-center text-center px-4" style={`animation-delay: ${i * 100}ms`}>
            <!-- Step number circle -->
            <div class={`relative z-10 flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br ${step.gradient} text-white font-extrabold text-sm shadow-lg mb-5 ring-4 ring-gray-900`}>
              {step.number}
            </div>
            <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed max-w-[180px]">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="lg:hidden relative pl-8">
      <!-- Vertical line -->
      <div class="absolute left-3 top-2 bottom-2 w-px bg-gradient-to-b from-indigo-500/40 via-purple-500/40 to-orange-500/40" aria-hidden="true"></div>

      <div class="space-y-10">
        {steps.map((step, i) => (
          <div class="relative reveal-up" style={`animation-delay: ${i * 80}ms`}>
            <!-- Dot on line -->
            <div class={`absolute -left-[1.85rem] top-0 flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-br ${step.gradient} text-white text-xs font-bold shadow-md ring-4 ring-gray-900`} aria-hidden="true">
              {step.number}
            </div>
            <div class="pl-4">
              <h3 class="text-base font-semibold text-white mb-1.5">{step.title}</h3>
              <p class="text-sm text-gray-400 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
