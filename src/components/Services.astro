---

<section id="services" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-950">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">What we do</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Services built for scale
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
        From product concept to production deployment — we cover the full stack so you can focus on growing your business.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((s, i) => (
        <div
          class={`service-card group relative p-6 rounded-2xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/80 hover:bg-gray-900 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${s.shadow} reveal-up`}
          style={`animation-delay: ${i * 80}ms`}
        >
          <div class={`inline-flex w-12 h-12 rounded-xl bg-gradient-to-br ${s.gradient} items-center justify-center mb-5 text-white shadow-lg ${s.shadow} group-hover:scale-110 transition-transform duration-300`}>
            <div class="w-6 h-6" set:html={s.icon} />
          </div>
          <h3 class="text-base font-semibold text-white mb-2.5">{s.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{s.description}</p>
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${s.gradient} opacity-0 group-hover:opacity-5 transition-opacity duration-300 pointer-events-none`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
