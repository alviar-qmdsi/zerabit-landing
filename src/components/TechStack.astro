---
const technologies = [
  { name: 'React', category: 'Frontend' },
  { name: 'Next.js', category: 'Frontend' },
  { name: 'Astro', category: 'Frontend' },
  { name: 'Node.js', category: 'Backend' },
  { name: 'Python', category: 'Backend' },
  { name: 'Go', category: 'Backend' },
  { name: 'AWS', category: 'Cloud' },
  { name: 'GCP', category: 'Cloud' },
  { name: 'Azure', category: 'Cloud' },
  { name: 'Docker', category: 'DevOps' },
  { name: 'Kubernetes', category: 'DevOps' },
  { name: 'Terraform', category: 'DevOps' },
];

const categoryColors: Record<string, string> = {
  Frontend: 'text-indigo-400 bg-indigo-500/10 border-indigo-500/20',
  Backend: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  Cloud: 'text-sky-400 bg-sky-500/10 border-sky-500/20',
  DevOps: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
};
---

<section id="tech-stack" class="py-24 px-4 sm:px-6 lg:px-8 bg-gray-950">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Our toolkit</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Technologies we trust
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
        We pick the right tool for every job — battle-tested technologies that perform at scale.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 reveal-up-delay">
      {technologies.map((tech, i) => (
        <div
          class="group flex flex-col items-center gap-3 p-5 rounded-2xl bg-gray-900/60 border border-gray-800/60 hover:border-gray-700/80 hover:bg-gray-900 transition-all duration-300 hover:-translate-y-1 cursor-default"
          style={`animation-delay: ${i * 50}ms`}
        >
          <!-- Tech initial badge -->
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-gray-800 border border-gray-700/60 group-hover:border-gray-600/80 transition-colors duration-300">
            <span class="text-lg font-extrabold text-white tracking-tight">
              {tech.name.slice(0, 2)}
            </span>
          </div>
          <div class="text-center">
            <p class="text-sm font-semibold text-white mb-1.5">{tech.name}</p>
            <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium border ${categoryColors[tech.category]}`}>
              {tech.category}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
