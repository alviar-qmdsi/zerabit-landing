---
const technologies = [
  { name: 'React', category: 'Frontend', icon: '⚛' },
  { name: 'Next.js', category: 'Frontend', icon: '▲' },
  { name: 'Astro', category: 'Frontend', icon: '🚀' },
  { name: 'TypeScript', category: 'Frontend', icon: 'TS' },
  { name: 'Node.js', category: 'Backend', icon: '⬡' },
  { name: 'Python', category: 'Backend', icon: '🐍' },
  { name: 'Go', category: 'Backend', icon: 'Go' },
  { name: 'PostgreSQL', category: 'Backend', icon: '🐘' },
  { name: 'AWS', category: 'Cloud', icon: '☁' },
  { name: 'GCP', category: 'Cloud', icon: '◈' },
  { name: 'Azure', category: 'Cloud', icon: '◆' },
  { name: 'Vercel', category: 'Cloud', icon: '▲' },
  { name: 'Docker', category: 'DevOps', icon: '🐳' },
  { name: 'Kubernetes', category: 'DevOps', icon: '☸' },
  { name: 'Terraform', category: 'DevOps', icon: '◇' },
  { name: 'GitHub Actions', category: 'DevOps', icon: '⚙' },
];

const categoryColors: Record<string, { pill: string; dot: string }> = {
  Frontend: { pill: 'text-indigo-400 bg-indigo-500/10 border-indigo-500/20', dot: 'bg-indigo-400' },
  Backend:  { pill: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20', dot: 'bg-emerald-400' },
  Cloud:    { pill: 'text-sky-400 bg-sky-500/10 border-sky-500/20', dot: 'bg-sky-400' },
  DevOps:   { pill: 'text-amber-400 bg-amber-500/10 border-amber-500/20', dot: 'bg-amber-400' },
};

// Duplicate for seamless infinite loop
const doubled = [...technologies, ...technologies];
---

<section id="tech-stack" class="py-24 bg-gray-950 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal-up">
      <span class="inline-block mb-3 text-indigo-400 text-sm font-semibold uppercase tracking-wider">Our toolkit</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 tracking-tight">
        Technologies we trust
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg leading-relaxed">
        We pick the right tool for every job — battle-tested technologies that perform at scale.
      </p>
    </div>
  </div>

  <!-- Marquee track (full bleed) -->
  <div class="relative w-full overflow-hidden" aria-label="Technologies we use">
    <!-- Left/right fade masks -->
    <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none bg-gradient-to-r from-gray-950 to-transparent" aria-hidden="true"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none bg-gradient-to-l from-gray-950 to-transparent" aria-hidden="true"></div>

    <div class="marquee-track gap-4 py-2">
      {doubled.map((tech) => {
        const colors = categoryColors[tech.category];
        return (
          <div class="flex-shrink-0 flex items-center gap-3 px-5 py-4 rounded-2xl bg-gray-900/70 border border-gray-800/70 hover:border-gray-700/80 hover:bg-gray-900 transition-all duration-300 cursor-default group mx-2">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gray-800 border border-gray-700/60 group-hover:border-gray-600/80 transition-colors duration-200 text-base select-none">
              {tech.icon}
            </div>
            <div>
              <p class="text-sm font-semibold text-white whitespace-nowrap">{tech.name}</p>
              <span class={`inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-[10px] font-semibold border ${colors.pill}`}>
                <span class={`w-1 h-1 rounded-full ${colors.dot}`}></span>
                {tech.category}
              </span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
